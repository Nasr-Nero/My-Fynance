generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id        String    @id @default(cuid())
  name      String
  stock     Int       @default(0)
  price     Float
  sales     Sale[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Sale {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  total     Float
  date      DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  category    String
  date        DateTime @default(now())
}
